<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>VB SHOP — Premium Dijital Ürünler</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: #04040c; color: #fff; font-family: 'Space Grotesk', 'Outfit', sans-serif; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: #08080f; }
  ::-webkit-scrollbar-thumb { background: linear-gradient(#7C3AED,#06B6D4); border-radius: 2px; }

  /* ── SCANLINE OVERLAY ── */
  body::before {
    content:'';position:fixed;inset:0;z-index:999;pointer-events:none;
    background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);
  }

  /* ── ANIMATIONS ── */
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-13px)} }
  @keyframes glow-pulse { 0%,100%{opacity:.45} 50%{opacity:.85} }
  @keyframes stagger-in { from{opacity:0;transform:translateY(26px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }
  @keyframes modal-pop { from{opacity:0;transform:scale(.94) translateY(13px)} to{opacity:1;transform:scale(1) translateY(0)} }
  @keyframes fade-in { from{opacity:0} to{opacity:1} }
  @keyframes badge-pulse { 0%,100%{box-shadow:0 0 8px rgba(124,58,237,.28)} 50%{box-shadow:0 0 20px rgba(124,58,237,.6)} }
  @keyframes hero-in { from{opacity:0;transform:translateY(36px)} to{opacity:1;transform:translateY(0)} }
  @keyframes neon-flicker {
    0%,19%,21%,23%,25%,54%,56%,100% { text-shadow: 0 0 7px #fff, 0 0 10px #fff, 0 0 21px #fff, 0 0 42px #7C3AED, 0 0 82px #7C3AED; }
    20%,24%,55% { text-shadow: none; }
  }
  @keyframes glitch {
    0%,100% { clip-path:inset(0 0 98% 0); transform:translate(-2px,0); }
    20% { clip-path:inset(30% 0 50% 0); transform:translate(2px,0); }
    40% { clip-path:inset(60% 0 20% 0); transform:translate(-1px,0); }
    60% { clip-path:inset(10% 0 80% 0); transform:translate(1px,0); }
    80% { clip-path:inset(80% 0 5% 0); transform:translate(-2px,0); }
  }
  @keyframes rgb-border {
    0%,100% { border-color: #7C3AED; box-shadow: 0 0 12px #7C3AED44; }
    33% { border-color: #06B6D4; box-shadow: 0 0 12px #06B6D444; }
    66% { border-color: #A855F7; box-shadow: 0 0 12px #A855F744; }
  }
  @keyframes crt-on {
    0% { transform:scaleY(0.01) scaleX(1.1); opacity:0.8; }
    30% { transform:scaleY(1.02) scaleX(1); opacity:1; }
    100% { transform:scaleY(1) scaleX(1); opacity:1; }
  }

  /* Shine sweep */
  @keyframes card-shine {
    0%,5%   { transform: translateX(-160%) rotate(28deg); opacity:0; }
    7%      { opacity:1; }
    24%,100%{ transform: translateX(240%) rotate(28deg); opacity:0; }
  }
  @keyframes stripe-breathe { 0%,100%{opacity:.06} 50%{opacity:.13} }

  .hidden { display: none !important; }

  /* ── HEADER ── */
  .header {
    position: sticky; top: 0; z-index: 100;
    backdrop-filter: blur(22px) saturate(1.5);
    background: rgba(4,4,12,.95);
    border-bottom: 1px solid rgba(124,58,237,.3);
    padding: 12px 26px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: 0 1px 0 rgba(124,58,237,.2), 0 4px 30px rgba(0,0,0,.5);
  }
  .logo-wrap { cursor: pointer; user-select: none; display: flex; align-items: center; gap: 10px; }
  .logo-icon { 
    width:36px;height:36px;border-radius:8px;
    background:linear-gradient(135deg,#7C3AED,#06B6D4);
    display:flex;align-items:center;justify-content:center;font-size:16px;
    box-shadow:0 0 18px rgba(124,58,237,.6);
    border:1px solid rgba(124,58,237,.5);
  }
  .logo-text { 
    font-size:20px;font-weight:900;letter-spacing:1px;
    background:linear-gradient(135deg,#fff,#c4b5fd,#67e8f9);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    text-transform:uppercase;
  }
  .villain-tag { 
    font-size:9px;color:#4b5563;font-weight:700;
    border-left:1px solid rgba(124,58,237,.3);
    padding-left:9px;margin-left:2px;letter-spacing:3px;
    text-transform:uppercase;
  }
  

  /* ── HERO ── */
  .hero { position:relative;z-index:5;text-align:center;padding:72px 20px 30px;animation:crt-on .5s ease both; }
  .hero-badge { 
    display:inline-flex;align-items:center;gap:7px;
    background:rgba(124,58,237,.08);
    border:1px solid rgba(124,58,237,.4);
    border-radius:4px;padding:5px 15px 5px 9px;
    font-size:10px;color:#a78bfa;letter-spacing:4px;
    text-transform:uppercase;margin-bottom:22px;
    animation:rgb-border 4s ease infinite;
    font-family:'JetBrains Mono',monospace;
  }
  .hero-dot { width:6px;height:6px;border-radius:50%;background:#7C3AED;box-shadow:0 0 10px #7C3AED,0 0 20px #7C3AED; }
  .hero-h1 { 
    font-size:clamp(36px,6vw,72px);font-weight:900;line-height:1.02;
    background:linear-gradient(160deg,#fff 10%,#c4b5fd 50%,#67e8f9 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    letter-spacing:-1px;
    position:relative;
  }
  .hero-h1::after {
    content:attr(data-text);
    position:absolute;left:0;top:0;width:100%;
    background:linear-gradient(160deg,#ff0080,#7C3AED,#06B6D4);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    animation:glitch 6s ease infinite;
    opacity:.4;
  }
  .hero-sub { 
    color:#4b5563;margin:14px auto 0;font-size:14px;
    max-width:380px;font-weight:500;line-height:1.7;
    letter-spacing:.5px;
  }

  /* ── INLINE CODE BOX ── */
  .hero-code-box { margin:30px auto 0;max-width:470px;background:rgba(255,255,255,.028);border:1px solid rgba(124,58,237,.24);border-radius:20px;padding:20px 22px;position:relative;overflow:hidden; }
  .hero-code-box::before { content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(124,58,237,.11) 0%,transparent 70%);pointer-events:none; }
  .hcb-label { font-size:11px;color:#7C3AED;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:11px;display:flex;align-items:center;gap:5px; }
  .hcb-row { display:flex;gap:9px;align-items:stretch; }
  .hcb-input { flex:1;background:rgba(0,0,0,.38);border:1.5px solid rgba(124,58,237,.3);border-radius:11px;padding:12px 15px;color:#fff;font-size:18px;font-weight:700;font-family:'JetBrains Mono',monospace;letter-spacing:3px;text-align:center;outline:none;transition:border-color .2s,box-shadow .2s; }
  .hcb-input::placeholder { color:#2d2d45;letter-spacing:2px;font-size:14px; }
  .hcb-input:focus { border-color:rgba(124,58,237,.65);box-shadow:0 0 22px rgba(124,58,237,.18); }
  .hcb-input.err { border-color:#ef4444; }
  .hcb-btn { background:linear-gradient(135deg,#7C3AED,#3B82F6);border:none;border-radius:11px;padding:12px 20px;color:#fff;font-weight:800;font-size:14px;cursor:pointer;white-space:nowrap;font-family:'Outfit',sans-serif;box-shadow:0 0 26px rgba(124,58,237,.38);transition:all .2s; }
  .hcb-btn:hover { filter:brightness(1.12);transform:translateY(-1px); }
  .hcb-btn:disabled { opacity:.5;cursor:not-allowed;transform:none; }
  .hcb-label-sub { font-size:10px;color:#374151;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:10px;font-family:'JetBrains Mono',monospace; }
  .hcb-cyan-wrap { border:1.5px solid #06B6D4;border-radius:10px;padding:3px;margin-bottom:12px;box-shadow:0 0 18px rgba(6,182,212,.18),inset 0 0 12px rgba(6,182,212,.04); }
  .hcb-cyan-input { width:100%;background:rgba(0,0,0,.5);border:none;border-radius:7px;padding:14px 18px;color:#fff;font-size:20px;font-weight:700;font-family:'JetBrains Mono',monospace;letter-spacing:4px;text-align:center;outline:none; }
  .hcb-cyan-input::placeholder { color:#1e3a3a;letter-spacing:3px;font-size:14px; }
  .hcb-cyan-btn { width:100%;background:#06B6D4;border:none;border-radius:10px;padding:15px;color:#000;font-weight:900;font-size:14px;cursor:pointer;font-family:'Outfit',sans-serif;letter-spacing:2px;box-shadow:0 0 28px rgba(6,182,212,.45);transition:all .2s;margin-bottom:9px; }
  .hcb-cyan-btn:hover { background:#22d3ee;box-shadow:0 0 38px rgba(6,182,212,.65); }
  .hcb-cyan-btn:disabled { opacity:.5;cursor:not-allowed; }
  .hcb-hint { color:#2d2d45;font-size:11px;margin-top:9px;text-align:center;font-weight:500; }

  /* ── TRUST ROW ── */
  .trust-row { display:flex;justify-content:center;gap:30px;margin:34px auto 0;flex-wrap:wrap;max-width:480px; }
  .trust-item { text-align:center; }
  .trust-icon { font-size:21px; }
  .trust-title { font-weight:700;font-size:12px;margin-top:5px; }
  .trust-sub { font-size:11px;color:#4b5563;margin-top:1px; }

  /* ── PRODUCTS ── */
  .products-section { position:relative;z-index:5;max-width:1240px;margin:52px auto 0;padding:0 22px 76px; }
  .sec-head { display:flex;align-items:center;justify-content:space-between;margin-bottom:24px; }
  .sec-head h2 { font-size:17px;font-weight:800; }
  .prod-count { font-size:11px;color:#4b5563;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:7px;padding:3px 10px; }
  .products-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(268px,1fr));gap:18px; }

  /* ── PRODUCT CARD ── */
  @keyframes card-border-glow {
    0%,100% { box-shadow: 0 8px 30px rgba(0,0,0,.5), 0 0 0px rgba(124,58,237,0); border-color: rgba(255,255,255,.07); }
    50% { box-shadow: 0 8px 40px rgba(0,0,0,.6), 0 0 22px rgba(124,58,237,.35), 0 0 44px rgba(124,58,237,.12); border-color: rgba(124,58,237,.4); }
  }
  @keyframes card-inner-glow {
    0%,100% { opacity:.38; transform: scale(1); }
    50% { opacity:.85; transform: scale(1.18); }
  }
  .prod-card {
    border-radius:20px;overflow:hidden;position:relative;background:#0c0c1a;
    border:1px solid rgba(255,255,255,.07);
    box-shadow:0 8px 30px rgba(0,0,0,.5);
    transition:transform .35s cubic-bezier(.34,1.56,.64,1),box-shadow .35s ease;
    animation:stagger-in .55s ease both, card-border-glow 4s ease infinite;
    animation-delay:var(--sd,0s), var(--sd,0s);
    cursor:default;
  }
  .prod-card:hover { transform:translateY(-9px) scale(1.014);box-shadow:0 22px 56px rgba(0,0,0,.7),0 0 32px rgba(124,58,237,.4); }

  /* One slow shimmer sweep per cycle */
  .card-shine { position:absolute;inset:0;z-index:20;pointer-events:none;overflow:hidden;border-radius:20px; }
  .card-shine::after {
    content:'';position:absolute;top:-80%;left:-50%;width:52%;height:260%;
    background:linear-gradient(105deg,transparent 24%,rgba(255,255,255,.18) 44%,rgba(255,255,255,.38) 50%,rgba(255,255,255,.12) 57%,transparent 70%);
    transform:translateX(-160%) rotate(28deg);
    animation:card-shine 4.5s ease-in-out infinite;
    animation-delay:var(--sd,0s);
  }

  .card-top { position:relative;overflow:hidden;padding:20px 18px 16px;min-height:172px; }
  .card-stripes {
    position:absolute;inset:0;z-index:2;pointer-events:none;
    background-image:repeating-linear-gradient(-48deg,rgba(255,255,255,0) 0px,rgba(255,255,255,0) 17px,rgba(255,255,255,.032) 17px,rgba(255,255,255,.032) 19px);
    animation:stripe-breathe 6s ease infinite;
  }
  .card-glow { 
    position:absolute;top:-38px;right:-38px;width:180px;height:180px;
    border-radius:50%;filter:blur(32px);
    animation:card-inner-glow 3s ease infinite;
    animation-delay:var(--sd,0s);
    z-index:1;pointer-events:none;
  }
  /* Extra bottom glow */
  .card-top::after {
    content:'';position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);
    width:70%;height:60px;border-radius:50%;
    background:inherit;filter:blur(22px);opacity:.3;
    animation:glow-pulse 3s ease infinite;
    pointer-events:none;z-index:2;
  }
  .card-fade { position:absolute;bottom:0;left:0;right:0;height:48px;z-index:3;pointer-events:none; }
  .card-bg-overlay { position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(0,0,0,.16) 0%,rgba(0,0,0,.52) 100%); }

  .card-brand-row { position:relative;z-index:10;display:flex;justify-content:space-between;align-items:flex-start; }
  .brand-logo-wrap { position:relative;width:54px;height:54px;border-radius:13px;overflow:hidden;flex-shrink:0;border:1.5px solid rgba(255,255,255,.16);box-shadow:0 4px 14px rgba(0,0,0,.5); }
  .brand-fallback { display:flex;align-items:center;justify-content:center;font-weight:900;font-family:'Outfit',sans-serif;width:100%;height:100%; }
  .card-tier-badge { background:rgba(0,0,0,.52);backdrop-filter:blur(8px);padding:4px 11px;border-radius:100px;font-size:11px;font-weight:700;color:#fff;border:1px solid rgba(255,255,255,.13);z-index:10;position:relative; }
  .card-name { font-size:19px;font-weight:900;color:#fff;position:relative;z-index:10;margin-top:11px;text-shadow:0 2px 10px rgba(0,0,0,.6); }
  .card-desc { font-size:12px;color:rgba(255,255,255,.58);position:relative;z-index:10;margin-top:3px;font-weight:500; }

  .card-bottom { background:rgba(6,6,14,.96);border-top:1px solid rgba(255,255,255,.06);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;position:relative;overflow:hidden; }
  .card-bottom::before { content:'';position:absolute;inset:0;background:repeating-linear-gradient(90deg,rgba(124,58,237,.065) 0px,rgba(99,102,241,.055) 14px,rgba(6,182,212,.055) 28px,rgba(124,58,237,.065) 42px);pointer-events:none; }
  .stock-row { display:flex;align-items:center;gap:5px;position:relative;z-index:1; }
  .stock-dot { width:7px;height:7px;border-radius:50%;background:#10B981;box-shadow:0 0 10px #10B981cc; }
  .stock-label { font-size:11px;color:#34d399;font-weight:600; }
  .card-access { font-size:11px;color:#374151;position:relative;z-index:1; }

  /* ── HOW IT WORKS ── */
  .how-section { margin-top:60px;text-align:center; }
  .how-section h3 { font-size:13px;font-weight:800;margin-bottom:26px;color:#9ca3af;letter-spacing:1.5px;text-transform:uppercase; }
  .how-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:14px; }
  .how-card { background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);border-radius:13px;padding:18px 14px;text-align:center; }
  .how-num { width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#7C3AED,#3B82F6);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;margin:0 auto 9px; }
  .how-emoji { font-size:20px;margin-bottom:6px; }
  .how-title { font-weight:700;font-size:13px;margin-bottom:3px; }
  .how-desc { font-size:11px;color:#4b5563;line-height:1.5; }

  /* ── AMBIENT ── */
  .glob { position:fixed;border-radius:50%;pointer-events:none;z-index:0; }
  .glob1 { top:12%;left:8%;width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,.08) 0%,transparent 70%);animation:float 9s ease infinite; }
  .glob2 { bottom:8%;right:4%;width:380px;height:380px;background:radial-gradient(circle,rgba(6,182,212,.07) 0%,transparent 70%);animation:float 12s ease infinite 2.5s; }
  .glob3 { top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(168,85,247,.03) 0%,transparent 70%);animation:float 15s ease infinite 1s; }
  #bg-canvas { position:fixed;inset:0;z-index:0;pointer-events:none; }

  /* ── FOOTER ── */
  .footer { 
    position:relative;z-index:5;
    border-top:1px solid rgba(124,58,237,.2);
    padding:18px 26px;
    display:flex;justify-content:space-between;align-items:center;
    color:#374151;font-size:12px;flex-wrap:wrap;gap:8px;
    background:rgba(4,4,12,.8);
  }
  .footer-brand { font-weight:900;color:#7C3AED;font-size:13px;letter-spacing:2px;text-transform:uppercase; }
  .footer-dev { font-size:11px;color:#4b5563; }
  .footer-dev span { color:#06B6D4;font-weight:700; }

  /* ── MODAL ── */
  .modal-overlay { position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center;padding:18px; }
  .modal-backdrop { position:absolute;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(10px); }
  .modal-box { position:relative;z-index:1;width:100%;max-width:460px;max-height:90vh;overflow-y:auto;background:linear-gradient(160deg,rgba(16,10,34,.97),rgba(7,7,18,.99));border:1px solid rgba(124,58,237,.2);border-radius:22px;padding:26px;box-shadow:0 0 56px rgba(124,58,237,.11),0 38px 76px rgba(0,0,0,.55);animation:modal-pop .3s cubic-bezier(.34,1.56,.64,1) both; }
  .modal-close { position:absolute;top:13px;right:13px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.07);border-radius:8px;width:29px;height:29px;color:#9ca3af;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;transition:background .2s; }
  .modal-close:hover { background:rgba(255,255,255,.1); }
  .modal-icon { width:58px;height:58px;border-radius:15px;background:linear-gradient(135deg,#7C3AED,#06B6D4);display:flex;align-items:center;justify-content:center;font-size:27px;margin:0 auto 13px;box-shadow:0 0 34px rgba(124,58,237,.42); }
  .modal-title { font-size:20px;font-weight:900;margin:0 0 5px;text-align:center; }
  .modal-sub { color:#4b5563;font-size:13px;text-align:center;font-weight:500; }

  .creds-box { background:rgba(0,0,0,.26);border-radius:13px;overflow:hidden;margin-bottom:13px;border:1px solid rgba(255,255,255,.055); }
  .cred-row { display:flex;justify-content:space-between;align-items:center;padding:12px 15px;border-bottom:1px solid rgba(255,255,255,.04); }
  .cred-row:last-child { border-bottom:none; }
  .cred-key { color:#9ca3af;font-size:13px;font-weight:600; }
  .cred-val { color:#fff;font-weight:700;font-size:14px;font-family:'JetBrains Mono',monospace;max-width:195px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap; }
  .copy-btn { border:none;border-radius:7px;padding:5px 10px;background:rgba(124,58,237,.13);color:#a78bfa;cursor:pointer;font-size:11px;font-weight:700;font-family:'Outfit',sans-serif;transition:all .2s; }
  .copy-btn.ok { background:rgba(16,185,129,.17);color:#34d399; }

  /* ── STEP1 USAGE BOX ── */
  .s1-usage-box { background:rgba(0,0,0,.28);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px 16px;margin:14px 0 10px; }
  .s1-usage-row { display:flex;justify-content:space-between;align-items:center;margin-bottom:8px; }
  .s1-usage-label { font-size:10px;color:#6b7280;letter-spacing:2px;text-transform:uppercase;font-family:'JetBrains Mono',monospace; }
  .s1-usage-val { font-size:13px;font-weight:900;color:#ef4444;font-family:'JetBrains Mono',monospace; }
  .s1-usage-bar { height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden; }
  .s1-usage-fill { width:100%;height:100%;background:linear-gradient(90deg,#ef4444,#f87171);border-radius:2px; }
  .s1-info-box { background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.2);border-radius:10px;padding:11px 14px;font-size:12px;color:#c4b5fd;line-height:1.6;margin-bottom:10px;text-align:left; }

  /* ── LIBRARY ── */
  .lib-section { position:relative;z-index:5;max-width:1240px;margin:0 auto;padding:0 22px 52px; }
  .lib-header { margin-bottom:18px; }
  .lib-title-row { display:flex;align-items:center;gap:9px;margin-bottom:4px; }
  .lib-icon { font-size:18px; }
  .lib-title { font-size:17px;font-weight:800; }
  .lib-badge { background:rgba(124,58,237,.16);color:#a78bfa;font-size:11px;font-weight:700;padding:2px 9px;border-radius:6px; }
  .lib-sub { font-size:12px;color:#374151; }
